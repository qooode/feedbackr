# --- REQUIRED ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# PocketBase superuser (auto-created on first boot)
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=change-me-to-a-strong-password

# Emails that get auto-promoted to admin on login (comma-separated)
ADMIN_EMAILS=you@example.com

# --- OPTIONAL ---
# AI model (default: anthropic/claude-sonnet-4)
# AI_MODEL=anthropic/claude-sonnet-4

# Your app URL
# APP_URL=https://feedback.yourdomain.com

# Discord OAuth (configure in PocketBase admin after first boot)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
